	let l_32382 = l_32381.next | l_32382.edges = (q_251 -> q_254) &&
	let l_32383 = l_32382.next | l_32383.edges = (q_251 -> q_255) +
                                                     (q_252 -> q_253) &&
	let l_32384 = l_32383.next | l_32384.edges = (q_252 -> q_254) &&
	let l_32385 = l_32384.next | l_32385.edges = (q_252 -> q_255) +
                                                     (q_253 -> q_254) &&
	let l_32386 = l_32385.next | l_32386.edges = (q_253 -> q_255) &&
	let l_32387 = l_32386.next | l_32387.edges = (q_254 -> q_255)
}

pred teleport[loc: Qubit -> Machine, r: Qubit -> Qubit, uloc: Qubit -> Machine, tele: Int, utele: Int] {
    all disj q0, q1: Qubit | (q0 -> q1 in r) implies q0.uloc = q1.uloc
    utele = plus[tele, #(uloc - loc)]
}

fact layerTransition {
    all l: circGraph, us: grph/next[l] { 
	teleport[l.location, us.edges, us.location, l.numTele, us.numTele] 
    }
}

pred finalLayer {  
    lte[grph/last.numTele, 1036416]
}

run finalLayer for 32388 circGraph, 24 Int
